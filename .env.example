# Optional paid/licensed data providers are disabled by default.
# Do not expose provider keys to frontend code; use them only in GitHub Actions,
# Docker updater jobs, or another backend/server-side data pipeline.

# Set to "1" only after choosing a provider and accepting its cost/quota/licensing.
WC2026_ENABLE_OPTIONAL_PROVIDERS=0

# Future provider examples. Leave empty unless the corresponding adapter exists.
WC2026_FORM_PROVIDER=
WC2026_FORM_API_KEY=
WC2026_ODDS_PROVIDER=
WC2026_ODDS_API_KEY=
WC2026_AVAILABILITY_PROVIDER=
WC2026_AVAILABILITY_API_KEY=
