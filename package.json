{
  "name": "2026worldcup-dashboard",
  "version": "1.0.0",
  "description": "2026 World Cup Dashboard: schedule, groups, bracket, teams, venues, weather, where to watch, and user-entered match predictions. Unofficial PWA",
  "keywords": [
    "world-cup",
    "world-cup-2026",
    "fifa",
    "football",
    "soccer",
    "schedule",
    "fixtures",
    "bracket",
    "standings",
    "prediction",
    "pwa",
    "offline-first",
    "i18n",
    "multilingual",
    "react",
    "vite",
    "typescript",
    "fan-made",
    "open-source"
  ],
  "homepage": "https://julianchun.github.io/2026worldcup-dashboard/",
  "bugs": {
    "url": "https://github.com/julianchun/2026worldcup-dashboard/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/julianchun/2026worldcup-dashboard.git"
  },
  "license": "MIT",
  "author": "Julian Chun",
  "type": "module",
  "engines": {
    "node": ">=25"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "update": "node scripts/update.mjs",
    "genmap": "node scripts/genmap.mjs",
    "gencron": "node scripts/gencron.mjs",
    "typecheck": "tsc -b",
    "lint": "biome check .",
    "a11y": "node scripts/a11y.mjs",
    "checkall": "npm run typecheck && npm run format && npm run lint",
    "checkall:build": "npm run checkall && npm run build && npm run smoke && npm run a11y",
    "smoke": "node scripts/smoke.mjs",
    "format": "biome format --write .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "axe-core": "^4.12.1",
    "opentype.js": "^2.0.0",
    "puppeteer-core": "^25.1.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0"
  }
}
